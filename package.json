	"private": true,
	"bin": {
		"ocr": "src/index.ts"
	},
	"dependencies": {
		"@aws-sdk/client-textract": "^3.888.0",
		"@aws-sdk/client-s3": "^3.888.0",
		"commander": "^14.0.1",
		"docx": "^9.5.0",
		"exceljs": "^4.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bun": "latest",
		"@types/node": "^24.0.0",
		"@typescript/native-preview": "^7.0.0-dev.20260122.3",
		"lefthook": "^1.7.10",
		"typescript": "^5.0.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"scripts": {
		"start": "bun run src/index.ts",
		"docker:build": "docker build -t phenome/ocr .",
		"lint": "biome check .",
